{
  "name": "@parallax/runtime-interface",
  "version": "0.1.0",
  "description": "Shared interfaces for Parallax agent runtimes",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
