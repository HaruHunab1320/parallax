# Terraform state and sensitive files
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
# Environment tfvars are safe (secrets are in GitHub Secrets, not here)
!gcp/environments/*.tfvars

# Terraform directories
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Sensitive variable files
*.auto.tfvars
*.auto.tfvars.json
