/**
 * @name SignalNoiseConversation
 * @version 1.1.0
 * @description Signal//Noise conversation loop — agents debate and rotate primary speaker based on confidence dominance
 * @input {"type": "object", "properties": {"topic": {"type": "string"}, "priorityWeights": {"type": "object"}, "previousResult": {"type": "object"}}}
 * @agents {"capabilities": ["conversation", "portfolio"]}
 * @minAgents 2
 */

// Access pre-processed agent results from this round
let results = agentResults
let count = agentCount

// Default priority weights per channel
let weights = input?.priorityWeights ?? {"prism": 0.9, "lumina": 0.7, "raven": 0.6, "89": 0.5}

// Determine primary channel from previous round's result
let primaryChannel = input?.previousResult?.nextPrimary ?? "prism"

// Build conversation history from previous round
let history = input?.previousResult?.history ?? []

// Separate primary and background results for this round
let primaryResult = null
let backgroundResults = []
let i = 0
while (i < results.length) {
  let agentChannel = results[i]?.result?.channel ?? ""
  if (agentChannel == primaryChannel) {
    primaryResult = results[i]
  } else {
    backgroundResults = [...backgroundResults, results[i]]
  }
  i = i + 1
}

// Apply priority weights and compute dominance scores
let rankedBackground = []
let highestDominance = 0
let nextPrimary = primaryChannel
let j = 0
while (j < backgroundResults.length) {
  let bgChannel = backgroundResults[j]?.result?.channel ?? ""
  let rawConf = backgroundResults[j]?.confidence ?? 0.5
  let weight = bgChannel != "" ? (weights[bgChannel] ?? 0.25) : 0.25
  let dominance = rawConf * weight
  let entry = {
    channel: bgChannel,
    agent: backgroundResults[j]?.agentName,
    message: backgroundResults[j]?.result?.message ?? "",
    confidence: rawConf,
    weight: weight,
    dominance: dominance
  }
  rankedBackground = [...rankedBackground, entry]

  // Track highest dominance background agent — they speak next
  if (dominance > highestDominance) {
    highestDominance = dominance
    if (bgChannel != "") {
      nextPrimary = bgChannel
    }
  }
  j = j + 1
}

// Extract primary agent info
let primaryChannel_out = primaryResult?.result?.channel ?? primaryChannel
let primaryMessage = primaryResult?.result?.message ?? ""
let primaryConf = primaryResult?.confidence ?? 0.5
let primaryWeight = weights[primaryChannel_out] ?? 0.5
let primaryDominance = primaryConf * primaryWeight

// Compute station-wide confidence
let totalConf = primaryConf
let k = 0
while (k < rankedBackground.length) {
  totalConf = totalConf + rankedBackground[k]?.confidence
  k = k + 1
}
let stationConfidence = count > 0 ? totalConf / count : 0

// Append this round to conversation history (keep last 10 rounds)
let thisRound = {
  round: history.length + 1,
  primary: {
    channel: primaryChannel_out,
    agent: primaryResult?.agentName ?? null,
    message: primaryMessage
  },
  background: rankedBackground
}
let newHistory = [...history, thisRound]
// Trim to last 10 rounds
let trimmedHistory = newHistory
if (newHistory.length > 10) {
  let startIdx = newHistory.length - 10
  trimmedHistory = []
  let m = startIdx
  while (m < newHistory.length) {
    trimmedHistory = [...trimmedHistory, newHistory[m]]
    m = m + 1
  }
}

// Build final result — includes nextPrimary for the chained scheduler
let result = {
  primary: {
    channel: primaryChannel_out,
    agent: primaryResult?.agentName ?? null,
    message: primaryMessage,
    confidence: primaryConf,
    dominance: primaryDominance
  },
  background: rankedBackground,
  stationConfidence: stationConfidence,
  agentCount: count,
  nextPrimary: nextPrimary,
  round: trimmedHistory.length,
  history: trimmedHistory,
  tuning: {
    primaryChannel: primaryChannel,
    weights: weights
  }
}

result ~> stationConfidence
